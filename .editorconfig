root = true

[*.{js,ts,jsx,tsx,java,xml,html,css,scss,json,md,yml,yaml,properties,sql,txt}]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space

[*.java]
indent_size = 4

[*.{js,ts,jsx,tsx,css,scss,html,xml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
