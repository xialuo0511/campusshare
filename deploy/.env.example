APP_PORT=8080
MYSQL_PORT=3306
REDIS_PORT=6379

MYSQL_DATABASE=campusshare
MYSQL_ROOT_PASSWORD=please_change_this_password
REDIS_PASSWORD=

SPRING_SQL_INIT_MODE=never

# Persistent application file storage. Keep this path mounted in docker-compose.
MATERIAL_STORAGE_ROOT=/data/campusshare/material-files

MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=your_qq_number@qq.com
# Use QQ Mail SMTP authorization code, not QQ login password.
MAIL_PASSWORD=your_qq_mail_authorization_code
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=false
MAIL_SMTP_SSL_ENABLE=true
MAIL_DISPATCH_FROM=your_qq_number@qq.com
MAIL_DISPATCH_ENABLED=false
MAIL_DISPATCH_SCHEDULER_ENABLED=false

REGISTER_CODE_MAIL_FROM=your_qq_number@qq.com
REGISTER_CODE_LOG_ENABLED=false
