<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xialuo.campusshare.module.governance.mapper.CommentMapper">

    <select id="CountCommentById" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM comment_info
        WHERE comment_id = #{commentId}
          AND deleted = 0
    </select>
</mapper>
