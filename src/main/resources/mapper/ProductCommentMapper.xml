<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xialuo.campusshare.module.resource.mapper.ProductCommentMapper">

    <resultMap id="CommentResultMap" type="com.xialuo.campusshare.entity.CommentEntity">
        <id column="comment_id" property="commentId"/>
        <result column="resource_id" property="resourceId"/>
        <result column="from_user_id" property="fromUserId"/>
        <result column="to_user_id" property="toUserId"/>
        <result column="score" property="score"/>
        <result column="content" property="content"/>
        <result column="hidden_flag" property="hiddenFlag"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <insert id="InsertComment" parameterType="com.xialuo.campusshare.entity.CommentEntity" useGeneratedKeys="true" keyProperty="commentId">
        INSERT INTO comment_info (
            resource_id,
            from_user_id,
            to_user_id,
            score,
            content,
            hidden_flag,
            create_time,
            update_time,
            deleted
        ) VALUES (
            #{resourceId},
            #{fromUserId},
            #{toUserId},
            #{score},
            #{content},
            #{hiddenFlag},
            #{createTime},
            #{updateTime},
            #{deleted}
        )
    </insert>

    <select id="ListCommentsByProductId" resultMap="CommentResultMap">
        SELECT
            comment_id,
            resource_id,
            from_user_id,
            to_user_id,
            score,
            content,
            hidden_flag,
            create_time,
            update_time,
            deleted
        FROM comment_info
        WHERE deleted = 0
          AND hidden_flag = 0
          AND resource_id = #{productId}
        ORDER BY create_time DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="CountCommentsByProductId" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM comment_info
        WHERE deleted = 0
          AND hidden_flag = 0
          AND resource_id = #{productId}
    </select>

    <select id="AverageScoreByProductId" resultType="java.math.BigDecimal">
        SELECT AVG(score)
        FROM comment_info
        WHERE deleted = 0
          AND hidden_flag = 0
          AND resource_id = #{productId}
          AND score IS NOT NULL
    </select>
</mapper>

