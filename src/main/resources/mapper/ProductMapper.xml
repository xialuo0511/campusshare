<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xialuo.campusshare.module.resource.mapper.ProductMapper">

    <resultMap id="ProductResultMap" type="com.xialuo.campusshare.entity.ProductEntity">
        <id column="product_id" property="productId"/>
        <result column="resource_id" property="resourceId"/>
        <result column="category" property="category"/>
        <result column="condition_level" property="conditionLevel"/>
        <result column="price" property="price"/>
        <result column="trade_location" property="tradeLocation"/>
        <result column="seller_user_id" property="sellerUserId"/>
        <result column="product_status" property="productStatus"/>
        <result column="on_shelf" property="onShelf"/>
        <result column="stock_count" property="stockCount"/>
        <result column="has_effective_order" property="hasEffectiveOrder"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <sql id="ProductColumns">
        product_id,
        resource_id,
        category,
        condition_level,
        price,
        trade_location,
        seller_user_id,
        product_status,
        on_shelf,
        stock_count,
        has_effective_order,
        create_time,
        update_time,
        deleted
    </sql>

    <select id="FindProductById" resultMap="ProductResultMap">
        SELECT
            <include refid="ProductColumns"/>
        FROM product_info
        WHERE product_id = #{productId}
          AND deleted = 0
        LIMIT 1
    </select>

    <update id="LockProductForOrder">
        UPDATE product_info
        SET
            has_effective_order = 1,
            product_status = 'LOCKED',
            update_time = #{updateTime}
        WHERE product_id = #{productId}
          AND deleted = 0
          AND on_shelf = 1
          AND has_effective_order = 0
          AND product_status = 'PUBLISHED'
    </update>

    <update id="ReleaseProductOrderLock">
        UPDATE product_info
        SET
            has_effective_order = 0,
            product_status = 'PUBLISHED',
            update_time = #{updateTime}
        WHERE product_id = #{productId}
          AND deleted = 0
          AND has_effective_order = 1
          AND product_status = 'LOCKED'
    </update>
</mapper>
